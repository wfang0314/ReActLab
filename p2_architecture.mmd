graph TB
    subgraph USER["🖥️ 用户层"]
        BROWSER["Web 浏览器<br/>SSE 流式交互"]
    end

    subgraph GATEWAY["🌐 API Gateway (FastAPI :9900)"]
        direction LR
        CHAT["/api/chat<br/>同步对话"]
        CHAT_SSE["/api/chat_stream<br/>SSE 流式对话"]
        AIOPS["/api/aiops<br/>Agent 工作流 SSE"]
        UPLOAD["/api/upload<br/>文档上传"]
        HEALTH["/api/health<br/>健康检查"]
    end

    subgraph AGENTS["🧠 Agent Runtime"]
        subgraph RAG["RAG Agent (LangChain)"]
            direction TB
            AGENT_CORE["create_agent<br/>ChatQwen qwen-max"]
            MEMORY["MemorySaver<br/>对话状态持久化"]
            MSG_TRIM["trim_messages<br/>上下文窗口管理"]
            AGENT_CORE --> MEMORY
            AGENT_CORE --> MSG_TRIM
        end
        subgraph PE["Plan-Execute-Replan Agent (LangGraph)"]
            direction LR
            PLANNER["Planner<br/>任务分解 + RAG"]
            EXECUTOR["Executor<br/>Tool Calling"]
            REPLANNER["Replanner<br/>评估 + 动态重规划"]
            REPORTER["Reporter<br/>Markdown 报告生成"]
            PLANNER --> EXECUTOR
            EXECUTOR --> REPLANNER
            REPLANNER -->|"继续执行"| EXECUTOR
            REPLANNER -->|"生成报告"| REPORTER
        end
    end

    subgraph TOOLS["🔧 工具层 (Tool Calling)"]
        KNOWLEDGE["retrieve_knowledge<br/>RAG 语义检索"]
        TIME_TOOL["get_current_time<br/>时间工具"]
        MCP_CLIENT["MCP Client<br/>指数退避重试"]
    end

    subgraph MCP["📡 MCP 服务 (Demo: 运维场景)"]
        CLS["CLS Server :8003<br/>日志查询"]
        MONITOR["Monitor Server :8004<br/>CPU/内存监控"]
    end

    subgraph INFRA["⚙️ 基础设施"]
        MILVUS[("Milvus 向量库<br/>Docker :19530")]
        DASHSCOPE["DashScope API<br/>qwen-max / embedding-v4"]
        DISK[("会话存储<br/>JSON File")]
    end

    subgraph DOC["📄 文档处理管线"]
        direction LR
        UPLOAD_DOC["文档上传"] --> SPLITTER["文档分割<br/>chunk=800+1600"]
        SPLITTER --> EMBED["向量化<br/>text-embedding-v4"]
        EMBED --> INDEX["索引构建<br/>Milvus Collection"]
    end

    BROWSER --> CHAT
    BROWSER --> CHAT_SSE
    BROWSER --> AIOPS
    BROWSER --> UPLOAD

    CHAT --> RAG
    CHAT_SSE --> RAG
    AIOPS --> PE
    UPLOAD --> DOC

    RAG --> TOOLS
    EXECUTOR --> TOOLS

    KNOWLEDGE --> MILVUS
    MCP_CLIENT --> CLS
    MCP_CLIENT --> MONITOR
    AGENT_CORE --> DASHSCOPE
    PLANNER --> DASHSCOPE
    REPLANNER --> DASHSCOPE
    MEMORY --> DISK
    INDEX --> MILVUS

    style USER fill:#e3f2fd,stroke:#1565c0
    style GATEWAY fill:#e8f5e9,stroke:#2e7d32
    style AGENTS fill:#f3e5f5,stroke:#7b1fa2
    style RAG fill:#fff3e0,stroke:#e65100
    style PE fill:#ede7f6,stroke:#4527a0
    style TOOLS fill:#fce4ec,stroke:#c62828
    style MCP fill:#e0f7fa,stroke:#00838f
    style INFRA fill:#f5f5f5,stroke:#616161
    style DOC fill:#fff8e1,stroke:#f9a825
