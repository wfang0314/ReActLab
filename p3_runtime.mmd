graph TB
    subgraph INPUT["📥 用户输入"]
        USER_INPUT["任务描述<br/>例：分析系统性能问题"]
    end

    subgraph PLANNER_NODE["1️⃣ Planner 规划节点"]
        direction TB
        RAG_LOOKUP["RAG 检索相关经验"]
        TOOL_LIST["获取可用工具列表"]
        LLM_PLAN["LLM 生成执行计划<br/>ChatQwen + structured output"]
        RAG_LOOKUP --> LLM_PLAN
        TOOL_LIST --> LLM_PLAN
        LLM_PLAN --> PLAN_OUT["输出: steps[]"]
    end

    subgraph EXECUTOR_NODE["2️⃣ Executor 执行节点"]
        direction TB
        NEXT_STEP["取出下一步 step[0]"]
        BIND_TOOLS["LLM bind_tools<br/>本地工具 + MCP 工具"]
        TOOL_CALL["ToolNode 自动执行"]
        COLLECT["收集执行结果"]
        NEXT_STEP --> BIND_TOOLS
        BIND_TOOLS --> TOOL_CALL
        TOOL_CALL --> COLLECT
    end

    subgraph TOOLS_DETAIL["🔧 工具集"]
        direction LR
        LOCAL["本地工具<br/>retrieve_knowledge<br/>get_current_time"]
        MCP_TOOLS["MCP 远程工具<br/>search_log<br/>query_cpu_metrics<br/>query_memory_metrics"]
        RETRY["指数退避重试<br/>delay × 2^attempt<br/>max_retries=3"]
        LOCAL --> RETRY
        MCP_TOOLS --> RETRY
    end

    subgraph REPLANNER_NODE["3️⃣ Replanner 评估节点"]
        direction TB
        EVAL["LLM 评估执行结果<br/>三个决策选项"]
        DECISION{"决策"}
        EVAL --> DECISION
        DECISION -->|"continue<br/>计划合理"| CONTINUE["继续执行剩余步骤"]
        DECISION -->|"replan<br/>需要调整"| REPLAN["动态重规划<br/>替换剩余 steps"]
        DECISION -->|"respond<br/>信息充足"| RESPOND["触发报告生成"]
    end

    subgraph REPORTER_NODE["4️⃣ Reporter 报告节点"]
        direction TB
        SUMMARIZE["综合执行历史"]
        GENERATE["LLM 生成 Markdown 诊断报告<br/>structured output"]
        SUMMARIZE --> GENERATE
        GENERATE --> OUTPUT["输出: 最终报告"]
    end

    subgraph STREAMING["📡 流式推送 (SSE)"]
        direction LR
        PLAN_EVENT["plan_created"]
        STEP_EVENT["step_complete"]
        EVAL_EVENT["replanner_status"]
        REPORT_EVENT["final_report"]
    end

    subgraph STATE["💾 状态管理"]
        MEMORY_SAVER["MemorySaver<br/>checkpointer"]
        STATE_FIELDS["State 字段<br/>input / plan[]<br/>past_steps[] / response"]
    end

    INPUT --> PLANNER_NODE
    PLAN_OUT --> EXECUTOR_NODE
    COLLECT --> REPLANNER_NODE
    CONTINUE --> EXECUTOR_NODE
    REPLAN --> EXECUTOR_NODE
    RESPOND --> REPORTER_NODE

    PLANNER_NODE -.->|"SSE 推送"| PLAN_EVENT
    EXECUTOR_NODE -.->|"SSE 推送"| STEP_EVENT
    REPLANNER_NODE -.->|"SSE 推送"| EVAL_EVENT
    REPORTER_NODE -.->|"SSE 推送"| REPORT_EVENT

    MEMORY_SAVER --> STATE_FIELDS
    STATE_FIELDS -.-> PLANNER_NODE
    STATE_FIELDS -.-> EXECUTOR_NODE
    STATE_FIELDS -.-> REPLANNER_NODE
    STATE_FIELDS -.-> REPORTER_NODE

    style INPUT fill:#e3f2fd,stroke:#1565c0
    style PLANNER_NODE fill:#fff3e0,stroke:#e65100
    style EXECUTOR_NODE fill:#e8f5e9,stroke:#2e7d32
    style TOOLS_DETAIL fill:#fce4ec,stroke:#c62828
    style REPLANNER_NODE fill:#f3e5f5,stroke:#7b1fa2
    style REPORTER_NODE fill:#ede7f6,stroke:#4527a0
    style STREAMING fill:#e0f7fa,stroke:#00838f
    style STATE fill:#f5f5f5,stroke:#616161
